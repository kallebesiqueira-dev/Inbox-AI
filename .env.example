# Copia questo file in `.env` e compila i valori. Nessun valore reale va committato.

# --- Ambiente ---
NODE_ENV=development

# --- Backend ---
PORT=4000
# Origini consentite dal CORS (separate da virgola). In produzione: il dominio del frontend.
CLIENT_URL=http://localhost:5173
# Slug del progetto Vercel: abilita le anteprime <slug>*.vercel.app nel CORS (opzionale).
VERCEL_PROJECT=
# Connessione MongoDB Atlas. Vuota = modalità demo in memoria (solo sviluppo).
MONGODB_URI=
# Segreto di firma dei JWT (min 32 caratteri in produzione).
# ATTENZIONE: la chiave AES dei token Gmail è derivata da questo segreto —
# ruotarlo invalida le sessioni e i collegamenti Gmail salvati.
JWT_SECRET=
# OAuth Google (accesso con Google + collegamento Gmail).
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Provider AI: "default" (euristica locale) oppure "groq" (LLM reale).
AI_PROVIDER=default
AI_API_KEY=
# Modello del provider AI (opzionale, es. per Groq: llama-3.3-70b-versatile).
AI_MODEL=
# SMTP per le email di sistema (reset password): Gmail + "password per le app".
GMAIL_APP_USER=
GMAIL_APP_PASSWORD=

# --- Frontend (Vite) ---
VITE_PORT=5173
# Proxy del dev server verso il backend locale.
VITE_API_PROXY=http://localhost:4000
# URL dell'API in produzione (vuoto in locale: si usa il proxy di Vite).
VITE_API_URL=
# Client ID Google per il bottone di accesso.
VITE_GOOGLE_CLIENT_ID=
