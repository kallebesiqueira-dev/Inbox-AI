NODE_ENV=development

# Frontend (Vite)
VITE_PORT=5173
VITE_API_PROXY=http://localhost:4000
VITE_API_URL=
VITE_GOOGLE_CLIENT_ID=

# Backend
PORT=4000
CLIENT_URL=http://localhost:5173
# Slug del progetto Vercel: abilita le anteprime <slug>-*.vercel.app nel CORS.
# Lasciare vuoto per non consentire alcun wildcard.
VERCEL_PROJECT=
MONGODB_URI=
JWT_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# AI provider (astratto, mai esposto al client)
AI_PROVIDER=default
AI_API_KEY=
